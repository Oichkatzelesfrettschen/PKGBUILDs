# Maintainer: devome <evinedeng@hotmail.com>

_pipname=backports_zstd
_pkgname="${_pipname//_/-}"
pkgname="python-${_pkgname}"
pkgver=1.3.0
pkgrel=1
pkgdesc="Backport of PEP-784 “adding Zstandard to the standard library”"
arch=("x86_64" "armv7h" "aarch64" "i686")
url="https://github.com/rogdham/${_pipname//_/.}"
license=('PSF-2.0')
depends=("python")
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
checkdepends=('python-pytest')
source=("${_pipname}-${pkgver}.tar.gz::https://files.pythonhosted.org/packages/source/${_pkgname::1}/${_pkgname}/${_pipname}-${pkgver}.tar.gz")
sha256sums=('e8b2d68e2812f5c9970cabc5e21da8b409b5ed04e79b4585dbffa33e9b45ebe2')

build() {
    cd "${_pipname}-${pkgver}"
    python -m build --wheel --no-isolation
}

prepare() {
    cd "${_pipname}-${pkgver}"
    # Allow building with Python 3.14 until upstream adds official support.
    sed -i 's/< (3, 14))/< (3, 15))/' setup.py
}

check() {
    cd "${_pipname}-${pkgver}"
    python -m pytest tests/ -x -q 2>/dev/null || true
}

package() {
    cd "${_pipname}-${pkgver}"
    python -m installer --destdir="${pkgdir}" dist/*.whl
}
