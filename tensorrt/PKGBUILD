# Maintainer: eirikr (custom build)
# Strategy: Wraps official NVIDIA PyPI wheels from pypi.nvidia.com
# Why: AUR tensorrt PKGBUILD source URL (developer.nvidia.com CDN) returns 404.
#      NVIDIA publishes the same TensorRT as binary wheels on pypi.nvidia.com.
#      C++ headers come from the corresponding GitHub release (29 MB source tarball).
#      tensorrt.so bindings are compiled for cp313; system Python is 3.14.
#      python-tensorrt installs to Python 3.13 site-packages.
#      Use python3.13 for TensorRT Python work.

pkgbase=tensorrt
pkgname=(tensorrt python-tensorrt)
pkgver=10.15.1.29
pkgrel=3
pkgdesc='NVIDIA TensorRT - high-performance deep learning inference on NVIDIA hardware'
arch=(x86_64)
url='https://developer.nvidia.com/tensorrt'
license=('LicenseRef-NvidiaTRT')

_libs_whl="tensorrt_cu13_libs-${pkgver}-py2.py3-none-manylinux_2_28_x86_64.whl"
_bind_whl="tensorrt_cu13_bindings-${pkgver}-cp313-none-manylinux_2_28_x86_64.whl"
_meta_sdist="tensorrt_cu13-${pkgver}.tar.gz"
# GitHub release tag: v${pkgver%.*.*}  -> v10.15 for 10.15.1.29
_ghver="v${pkgver%.*.*}"

source=(
    "https://pypi.nvidia.com/tensorrt-cu13-libs/${_libs_whl}"
    "https://pypi.nvidia.com/tensorrt-cu13-bindings/${_bind_whl}"
    "https://files.pythonhosted.org/packages/source/t/tensorrt_cu13/${_meta_sdist}"
    "TensorRT-${_ghver}.tar.gz::https://github.com/NVIDIA/TensorRT/archive/refs/tags/${_ghver}.tar.gz"
)
sha256sums=(
    '0619b60ba97425909c18442eb36cbe7f99b1a7eeb4ebf9c6b278e6e2c5ac6c3b'
    '4a065bbdc7d4ebd6c7e0fe635b9a9ed2b6b6431ba4cba5aa7f00c2d3eceb1ab8'
    '60edcdf1a68526732ea613c309283af036f418f6ebcbc8e18d24566b74d776e0'
    '65eb2442d9eda60a5430b845825c1de51bea265d79d28551352f656b98844fd4'
)
noextract=("${_libs_whl}" "${_bind_whl}")

_sitepkgs314="$(python3 -c 'import site; print(site.getsitepackages()[0])')"
_sitepkgs313="$(python3.13 -c 'import site; print(site.getsitepackages()[0])')"
# Arch for TRT library paths (x86_64-linux-gnu)
_trt_arch="${CARCH}-linux-gnu"

package_tensorrt() {
    pkgdesc='NVIDIA TensorRT C++ runtime libraries and headers'
    depends=(cuda cudnn 'nvidia-utils>=590')
    provides=('libnvinfer.so=10' 'libnvonnxparser.so=10' 'libnvinfer_plugin.so=10')

    # Install tensorrt_libs Python package (ctypes loader + .so files)
    python3 -m installer --destdir="$pkgdir" "${srcdir}/${_libs_whl}"

    # Install .so files to /usr/lib with unversioned symlinks
    install -d "${pkgdir}/usr/lib"
    for _so in "${pkgdir}${_sitepkgs314}/tensorrt_libs/"*.so*; do
        [[ -f "$_so" ]] || continue
        install -m755 "$_so" "${pkgdir}/usr/lib/"
        ln -sf "/usr/lib/$(basename "$_so")" "$_so"
    done
    # Create unversioned .so symlinks expected by build systems
    # libnvinfer.so.10 -> libnvinfer.so, etc.
    (
        cd "${pkgdir}/usr/lib"
        for _versioned in libnvinfer.so.10 libnvinfer_plugin.so.10 libnvonnxparser.so.10; do
            [[ -f "$_versioned" ]] && ln -sf "$_versioned" "${_versioned%.10}"
        done
    )

    # Install C++ headers from GitHub release source
    # GitHub tarball extracts to TensorRT-<version> (without 'v' prefix)
    local _trt_srcdir="${srcdir}/TensorRT-${_ghver#v}"
    install -d "${pkgdir}/usr/include"
    install -m644 "${_trt_srcdir}/include/"*.h "${pkgdir}/usr/include/"

    install -Dm644 "${srcdir}/TensorRT-${_ghver#v}/LICENSE" \
        "${pkgdir}/usr/share/licenses/tensorrt/LICENSE"
}

package_python-tensorrt() {
    pkgdesc='NVIDIA TensorRT Python 3.13 bindings (cp313; use python3.13 to import)'
    # tensorrt.so is compiled for CPython 3.13 - not compatible with 3.14.
    depends=(tensorrt python313 python-numpy)

    install -d "${pkgdir}${_sitepkgs313}"
    bsdtar -C "${pkgdir}${_sitepkgs313}" -xf "${srcdir}/${_bind_whl}" \
        'tensorrt_bindings/*' \
        "tensorrt_cu13_bindings-${pkgver}.dist-info/*"
    chmod 755 "${pkgdir}${_sitepkgs313}/tensorrt_bindings/tensorrt.so"

    # Install tensorrt namespace package (re-exports from tensorrt_bindings)
    local _ns="${pkgdir}${_sitepkgs313}/tensorrt"
    local _ns_plugin="${_ns}/plugin"
    install -d "${_ns}" "${_ns_plugin}"
    install -m644 "${srcdir}/tensorrt_cu13-${pkgver}/tensorrt/__init__.py" "${_ns}/"
    install -m644 "${srcdir}/tensorrt_cu13-${pkgver}/tensorrt/plugin/"*.py "${_ns_plugin}/"

    local _di="${pkgdir}${_sitepkgs313}/tensorrt_cu13-${pkgver}.dist-info"
    install -d "${_di}"
    cat > "${_di}/METADATA" << EOF
Metadata-Version: 2.1
Name: tensorrt-cu13
Version: ${pkgver}
Summary: TensorRT for CUDA 13 (packaged from pypi.nvidia.com wheels)
EOF
    printf 'tensorrt\ntensorrt_bindings\n' > "${_di}/top_level.txt"
    printf 'Wheel-Version: 1.0\nGenerator: PKGBUILD\nRoot-Is-Purelib: true\nTag: cp313-none-any\n' > "${_di}/WHEEL"

    install -Dm644 "${srcdir}/TensorRT-${_ghver#v}/LICENSE" \
        "${pkgdir}/usr/share/licenses/python-tensorrt/LICENSE"
}
