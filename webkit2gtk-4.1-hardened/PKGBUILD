# Maintainer: eirikr <151315375+Oichkatzelesfrettschen@users.noreply.github.com>
# Upstream: Jan Alexander Steffens (heftig) <heftig@archlinux.org>
# Why: Hardened, stripped, ThinLTO-optimized WebKitGTK for use as a minimal
#      secure webview runtime. Disables unused web platform features (gamepad,
#      geolocation, speech, WebRTC, WebXR, WebDriver, PDF.js, media capture,
#      notifications, spellcheck) to reduce attack surface, memory footprint,
#      and JIT warmup time. Enables all JIT tiers and GPU process isolation.
#      Provides/conflicts with the stock webkit2gtk-4.1 so it is a drop-in
#      replacement for Tauri apps, GNOME components, and anything else that
#      links against libwebkit2gtk-4.1.

pkgname=webkit2gtk-4.1-hardened
pkgver=2.50.6
pkgrel=1
pkgdesc="Hardened, stripped, ThinLTO-optimized web content engine for GTK"
url="https://webkitgtk.org"
arch=(x86_64)
license=(
