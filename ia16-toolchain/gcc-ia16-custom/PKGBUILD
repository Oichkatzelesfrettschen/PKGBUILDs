# Maintainer: Oichkatzelesfrettschen
# PKGBUILD for gcc-ia16-custom-git (full compiler with libc support)

pkgname=gcc-ia16-custom-git
pkgver=r1.main
pkgrel=1
pkgdesc="IA-16 GCC 6.3.0 with NEC V20/V30 support (full compiler)"
arch=('x86_64')
url="https://github.com/Oichkatzelesfrettschen/gcc-ia16-8088-custom"
license=('GPL-3.0-or-later')
depends=('binutils-ia16-custom-git' 'newlib-ia16-custom-git' 'gmp' 'mpfr' 'libmpc' 'zlib')
makedepends=('git' 'texinfo' 'flex' 'bison' 'libisl')
provides=('gcc-ia16' 'gcc-ia16-elf')
conflicts=('gcc-ia16' 'gcc-ia16-elf' 'gcc-ia16-custom-stage1-git')
replaces=('gcc-ia16-custom-stage1-git')
options=('!strip' '!buildflags')
source=("git+https://github.com/Oichkatzelesfrettschen/gcc-ia16-8088-custom.git#branch=main")
sha256sums=('SKIP')

_target=ia16-elf

pkgver() {
    cd "${srcdir}/gcc-ia16-8088-custom"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${srcdir}/gcc-ia16-8088-custom"

    # Clean any previous build
    rm -rf build-stage2
    mkdir -p build-stage2
    cd build-stage2

    # Ensure binutils and newlib are available
    export PATH="/opt/ia16/bin:$PATH"

    # Stage 2: Full build with newlib headers
    ../configure \
        --target=${_target} \
        --prefix=/opt/ia16 \
        --with-newlib \
        --with-headers=/opt/ia16/${_target}/include \
        --enable-languages=c,c++ \
        --disable-libssp \
        --disable-libquadmath \
        --disable-libgomp \
        --disable-libatomic \
        --disable-threads \
        --disable-shared \
        --disable-nls \
        --disable-werror

    make -j$(nproc)
}

package() {
    cd "${srcdir}/gcc-ia16-8088-custom/build-stage2"
    export PATH="/opt/ia16/bin:$PATH"
    make DESTDIR="${pkgdir}" install

    # Remove info pages (conflict with host gcc)
    rm -rf "${pkgdir}/opt/ia16/share/info"
    rm -rf "${pkgdir}/opt/ia16/share/man"

    # Create symlinks in /usr/local/bin
    install -d "${pkgdir}/usr/local/bin"
    for tool in "${pkgdir}/opt/ia16/bin/${_target}-"*; do
        ln -sf "/opt/ia16/bin/$(basename "$tool")" "${pkgdir}/usr/local/bin/"
    done
}
