# Maintainer: Oichkatzelesfrettschen
# PKGBUILD for binutils-ia16-custom-git

pkgname=binutils-ia16-custom-git
pkgver=r110781.f66be209
pkgrel=1
pkgdesc="IA-16 binutils with NEC V20/V30 extended instruction support"
arch=('x86_64')
url="https://github.com/Oichkatzelesfrettschen/binutils-ia16-custom"
license=('GPL-3.0-or-later')
depends=('zlib' 'libelf')
makedepends=('git' 'texinfo' 'flex' 'bison')
provides=('binutils-ia16' 'binutils-ia16-elf')
conflicts=('binutils-ia16' 'binutils-ia16-elf')
options=('!strip' '!buildflags')
source=("git+https://github.com/Oichkatzelesfrettschen/binutils-ia16-custom.git#branch=binutils-ia16-tkchia")
sha256sums=('SKIP')

_target=ia16-elf

pkgver() {
    cd "${srcdir}/binutils-ia16-custom"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${srcdir}/binutils-ia16-custom"

    # Clean any previous build
    rm -rf build
    mkdir -p build
    cd build

    ../configure \
        --target=${_target} \
        --prefix=/opt/ia16 \
        --enable-ld=default \
        --enable-gold=yes \
        --enable-targets=${_target} \
        --enable-x86-hpa-segelf=yes \
        --disable-werror \
        --disable-nls \
        --with-sysroot=/opt/ia16/${_target}

    make -j$(nproc)
}

package() {
    cd "${srcdir}/binutils-ia16-custom/build"
    make DESTDIR="${pkgdir}" install

    # Remove info pages (conflict with host binutils)
    rm -rf "${pkgdir}/opt/ia16/share/info"

    # Create symlinks in /usr/local/bin for convenience
    install -d "${pkgdir}/usr/local/bin"
    for tool in "${pkgdir}/opt/ia16/bin/${_target}-"*; do
        ln -sf "/opt/ia16/bin/$(basename "$tool")" "${pkgdir}/usr/local/bin/"
    done
}
