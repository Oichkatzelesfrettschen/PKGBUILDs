# Maintainer: Oichkatzelesfrettschen
# PKGBUILD for newlib-ia16-custom-git

pkgname=newlib-ia16-custom-git
pkgver=r1.newlib
pkgrel=1
pkgdesc="IA-16 newlib C library with PATH_MAX fixes"
arch=('x86_64')
url="https://github.com/Oichkatzelesfrettschen/newlib-ia16-custom"
license=('BSD-3-Clause' 'GPL-3.0-or-later')
depends=('gcc-ia16-custom-stage1-git')
makedepends=('git' 'texinfo')
provides=('newlib-ia16' 'newlib-ia16-elf')
conflicts=('newlib-ia16' 'newlib-ia16-elf')
options=('!strip' '!buildflags')
source=("git+https://github.com/Oichkatzelesfrettschen/newlib-ia16-custom.git#branch=newlib-2_4_0-ia16-tkchia")
sha256sums=('SKIP')

_target=ia16-elf

pkgver() {
    cd "${srcdir}/newlib-ia16-custom"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${srcdir}/newlib-ia16-custom"

    # Clean any previous build
    rm -rf build
    mkdir -p build
    cd build

    # Ensure stage1 compiler is in PATH
    export PATH="/opt/ia16/bin:$PATH"

    ../configure \
        --target=${_target} \
        --prefix=/opt/ia16 \
        --enable-newlib-nano-malloc \
        --disable-newlib-wide-orient \
        --enable-newlib-io-c99-formats \
        --enable-newlib-io-long-long \
        --disable-newlib-multithread \
        --disable-newlib-supplied-syscalls

    make -j$(nproc)
}

package() {
    cd "${srcdir}/newlib-ia16-custom/build"
    export PATH="/opt/ia16/bin:$PATH"
    make DESTDIR="${pkgdir}" install

    # Install license
    install -Dm644 "${srcdir}/newlib-ia16-custom/COPYING.NEWLIB" \
        "${pkgdir}/usr/share/licenses/${pkgname}/COPYING.NEWLIB"
}
