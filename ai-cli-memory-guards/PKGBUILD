# Maintainer: eirikr <local@host>
pkgname=ai-cli-memory-guards
pkgver=0.1.0
pkgrel=2
pkgdesc='Memory-guard launcher wrappers for codex/claude/gemini/copilot'
arch=('any')
url='https://local/pkgbuilds/ai-cli-memory-guards'
license=('MIT')
depends=('bash')
optdepends=(
  'nodejs: Node runtime for NODE_OPTIONS support'
  'openai-codex-cli: codex wrapper target'
  'claude-code: claude wrapper target'
  'gemini-cli: gemini wrapper target'
  'github-copilot-cli: copilot wrapper target'
)
source=('ai-cli-guard' 'ai-cli-memory-guards.conf' 'README.md')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
  install -Dm755 ai-cli-guard "$pkgdir/usr/bin/codex-guard"
  install -Dm755 ai-cli-guard "$pkgdir/usr/bin/claude-guard"
  install -Dm755 ai-cli-guard "$pkgdir/usr/bin/gemini-guard"
  install -Dm755 ai-cli-guard "$pkgdir/usr/bin/copilot-guard"
  install -Dm644 ai-cli-memory-guards.conf "$pkgdir/etc/ai-cli-memory-guards.conf"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
