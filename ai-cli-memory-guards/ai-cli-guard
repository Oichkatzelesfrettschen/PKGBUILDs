#!/usr/bin/env bash
set -euo pipefail

# Wrapper for Node-based AI CLIs with optional memory/concurrency guardrails.

tool_name="$(basename "$0")"
tool_name="${tool_name%-guard}"

case "$tool_name" in
  codex|claude|gemini|copilot)
    ;;
  *)
    echo "ERROR: unsupported tool wrapper: $tool_name" >&2
    exit 2
    ;;
esac

# Optional host-level defaults.
if [[ -r /etc/ai-cli-memory-guards.conf ]]; then
  # shellcheck disable=SC1091
  . /etc/ai-cli-memory-guards.conf
fi

max_old_space="${AI_CLI_MAX_OLD_SPACE_SIZE:-3072}"
max_semi_space="${AI_CLI_MAX_SEMI_SPACE_SIZE:-64}"

# Preserve existing NODE_OPTIONS but ensure caps are appended.
export NODE_OPTIONS="${NODE_OPTIONS:-} --max-old-space-size=${max_old_space} --max-semi-space-size=${max_semi_space}"

extra_args=()

# Copilot-specific fanout guard supported natively by CLI.
if [[ "$tool_name" == "copilot" ]] && [[ "${AI_CLI_DISABLE_PARALLEL_TOOLS:-1}" == "1" ]]; then
  extra_args+=("--disable-parallel-tools-execution")
fi

if [[ "$tool_name" == "codex" ]] && [[ "${AI_CLI_CODEX_ENABLE_SEARCH:-0}" == "1" ]]; then
  extra_args+=("--search")
fi

exec "$tool_name" "${extra_args[@]}" "$@"
