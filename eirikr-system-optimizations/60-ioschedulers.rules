# I/O Scheduler Optimization Rules
# Target: /etc/udev/rules.d/60-ioschedulers.rules
# Optimizes I/O schedulers for different storage device types

# NVMe devices: Use 'none' scheduler for minimal overhead and maximum performance
# CachyOS may use ADIOS (Adaptive Deadline I/O Scheduler) instead - check with CachyOS defaults
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/scheduler}="none"

# SATA SSDs: Use 'mq-deadline' or 'bfq' for good balance
ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"

# HDDs: Use 'bfq' for better responsiveness
ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"

# Increase read-ahead for NVMe (already at 8192 KB, keep it)
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/read_ahead_kb}="8192"

# Disable I/O stats for NVMe to reduce overhead (optional, commented out by default)
# ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/iostats}="0"
