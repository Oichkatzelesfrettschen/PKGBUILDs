# Maintainer: eirikr <eirikr@localhost>
pkgname=tla-plus-toolbox
pkgver=1.7.4
pkgrel=2
pkgdesc="Integrated Development Environment for the TLA+ tools"
arch=('x86_64')
url="https://lamport.azurewebsites.net/tla/toolbox.html"
license=('MIT')
depends=('gtk3' 'webkit2gtk' 'java-runtime')
optdepends=('texlive-core: for PDF generation (tla2tex)')
makedepends=('unzip')
source=("https://github.com/tlaplus/tlaplus/releases/download/v${pkgver}/TLAToolbox-${pkgver}-linux.gtk.x86_64.zip"
        "tla-plus-toolbox.desktop")
sha256sums=('7982b671726f2c841f90afa89eba26c2135f026cd64b20995c2b04391c648da5'
            '468d74744d9b610df835d747a3932a189ac721a2479c8913fada0f334f256c2c')

package() {
  # The zip extracts to a 'toolbox' directory
  
  install -d "${pkgdir}/opt/${pkgname}"
  cp -a "${srcdir}/toolbox/"* "${pkgdir}/opt/${pkgname}/"
  
  install -d "${pkgdir}/usr/bin"
  ln -s "/opt/${pkgname}/toolbox" "${pkgdir}/usr/bin/${pkgname}"
  
  # Create CLI wrappers
  local _jar="/opt/${pkgname}/tla2tools.jar"
  
  # TLC Model Checker
  printf '#!/bin/sh\nexec java -cp "%s" tlc2.TLC "$@"\n' "${_jar}" > "${pkgdir}/usr/bin/tlc"
  
  # PlusCal Translator
  printf '#!/bin/sh\nexec java -cp "%s" pcal.trans "$@"\n' "${_jar}" > "${pkgdir}/usr/bin/pcal"
  
  # SANY Parser/Semantic Analyzer
  printf '#!/bin/sh\nexec java -cp "%s" tla2sany.SANY "$@"\n' "${_jar}" > "${pkgdir}/usr/bin/sany"
  
  # TLA+ to TeX
  printf '#!/bin/sh\nexec java -cp "%s" tla2tex.TLA "$@"\n' "${_jar}" > "${pkgdir}/usr/bin/tla2tex"
  
  chmod 755 "${pkgdir}/usr/bin/"{tlc,pcal,sany,tla2tex}
  
  install -Dm644 "${srcdir}/tla-plus-toolbox.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
  
  # Try to find an icon if it exists in the package
  find "${pkgdir}/opt/${pkgname}" -name "icon.xpm" -exec install -Dm644 {} "${pkgdir}/usr/share/pixmaps/${pkgname}.xpm" \; || true
}
