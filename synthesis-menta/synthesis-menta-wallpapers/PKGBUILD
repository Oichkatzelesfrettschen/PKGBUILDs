pkgname=synthesis-menta-wallpapers
pkgver=2.2.0
pkgrel=1
pkgdesc="SynthesisMenta wallpapers and background helper"
arch=('any')
url="https://github.com/Oichkatzelesfrettschen/Synthesis-Dark-Theme"
license=('GPL-3.0-or-later')
depends=('dconf')
makedepends=('git')
_theme_commit=a0b5e966
source=("Synthesis-Dark-Theme::git+${url}.git#commit=${_theme_commit}")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/Synthesis-Dark-Theme"
  make DESTDIR="${pkgdir}" PREFIX=/usr install-wallpapers
}
