# Maintainer: eirikr <151315375+Oichkatzelesfrettschen@users.noreply.github.com>

pkgname=synthesis-menta-icons-variants
pkgver=2.2.0
pkgrel=1
pkgdesc="SynthesisMenta generated icon theme variants"
arch=('any')
url="https://github.com/Oichkatzelesfrettschen/Synthesis-Dark-Theme"
license=('GPL-3.0-or-later')
depends=('hicolor-icon-theme' 'synthesis-menta-icons')
makedepends=('git' 'python-pillow')
_theme_commit=a0b5e966
source=("Synthesis-Dark-Theme::git+${url}.git#commit=${_theme_commit}")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/Synthesis-Dark-Theme"
  git submodule update --init upstream/tela-circle
}

build() {
  cd "${srcdir}/Synthesis-Dark-Theme"
  make clean
  make icons
  make icon-variants
}

package() {
  cd "${srcdir}/Synthesis-Dark-Theme"
  make DESTDIR="${pkgdir}" PREFIX=/usr install-icon-variants
}
