# Maintainer: eirikr <151315375+Oichkatzelesfrettschen@users.noreply.github.com>
# Note: GitHub-tracked only; not published to AUR (repackages official Arch archive binaries).
pkgname=gcc13-sidecar-bin
pkgver=13.3.0
pkgrel=1
pkgdesc="Secondary GCC 13 sidecar repackaged from Arch archive binaries"
arch=(x86_64)
url="https://archive.archlinux.org/"
license=(GPL-3.0-or-later LGPL-3.0-or-later FDL-1.3-or-later)
depends=(glibc binutils libmpc zstd libisl)
options=(!strip !debug)
source=(
  "https://archive.archlinux.org/packages/g/gcc13/gcc13-${pkgver}-1-x86_64.pkg.tar.zst"
  "https://archive.archlinux.org/packages/g/gcc13-libs/gcc13-libs-${pkgver}-1-x86_64.pkg.tar.zst"
  "gcc13-sidecar.sh"
  "README.md"
)
sha256sums=(
  "1156e1ab093ba66675da04992493727b824287254ce404455c2a9419f95c1e38"
  "1353c18b98d3cdc7d80194160a88a0451ee8ad07cfc33b210784ee376688014e"
  "a4c52e5235fa8dfff9d2ba3a25be2dda55633c8d1bdc329d9f4397b01fb994c9"
  "868891d6fa8c11e3f0653690329e326376292e5ab322802a03f68cf8a194c423"
)

package() {
  bsdtar -xpf "${srcdir}/gcc13-${pkgver}-1-x86_64.pkg.tar.zst" -C "${pkgdir}"
  bsdtar -xpf "${srcdir}/gcc13-libs-${pkgver}-1-x86_64.pkg.tar.zst" -C "${pkgdir}"
  rm -f "${pkgdir}/.BUILDINFO" "${pkgdir}/.MTREE" "${pkgdir}/.PKGINFO"

  install -Dm755 "${srcdir}/gcc13-sidecar.sh" "${pkgdir}/opt/gcc13-sidecar/gcc13-sidecar.sh"
  install -Dm644 "${srcdir}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
