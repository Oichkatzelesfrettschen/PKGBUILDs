 xdg.Config.setWindowManager('MATE')
 
+def _read_os_release():
+    values = {}
+    try:
+        with open("/etc/os-release", "r", encoding="utf-8") as handle:
+            for line in handle:
+                line = line.strip()
+                if not line or line.startswith("#") or "=" not in line:
+                    continue
+                key, value = line.split("=", 1)
+                values[key] = value.strip().strip('"').strip("'")
+    except OSError:
+        pass
+    return values
+
+def _candidate_icon_paths(token):
+    if not token:
+        return []
+
+    paths = []
+    for directory in ("/usr/share/icons", "/usr/share/pixmaps"):
+        for extension in (".svg", ".png", ".xpm"):
+            candidate = os.path.join(directory, token + extension)
+            if os.path.exists(candidate):
+                paths.append(candidate)
+    return paths
+
+def resolve_panel_icon():
+    icon_theme = Gtk.IconTheme.get_default()
+    os_release = _read_os_release()
+
+    candidates = []
+    logo = os_release.get("LOGO", "")
+    distro_id = os_release.get("ID", "")
+    distro_like = os_release.get("ID_LIKE", "").split()
+
+    if logo:
+        candidates.append(logo)
+    if distro_id:
+        candidates.append("distributor-logo-" + distro_id)
+    for token in distro_like:
+        candidates.append("distributor-logo-" + token)
+
+    for token in (logo, distro_id):
+        candidates.extend(_candidate_icon_paths(token))
+
+    candidates.extend(["distributor-logo", "start-here", "start-here-symbolic"])
+    for candidate in list(dict.fromkeys(filter(None, candidates))):
+        if os.path.isabs(candidate) and os.path.exists(candidate):
+            return candidate
+        if icon_theme.has_icon(candidate):
+            return candidate
+    return "start-here"
+
