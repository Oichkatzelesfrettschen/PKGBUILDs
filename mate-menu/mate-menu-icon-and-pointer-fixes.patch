+    def _window_contains_pointer(self, window, pointer_x, pointer_y):
+        if window is None:
+            return False
+
+        try:
+            origin = window.get_origin()
+            if isinstance(origin, tuple):
+                if len(origin) == 3:
+                    _, window_x, window_y = origin
+                else:
+                    window_x, window_y = origin
+            else:
+                window_x = origin.x
+                window_y = origin.y
+
+            width = window.get_width()
+            height = window.get_height()
+        except Exception:
+            return False
+
+        return (
+            pointer_x >= window_x and
+            pointer_y >= window_y and
+            pointer_x <= (window_x + width) and
+            pointer_y <= (window_y + height)
+        )
+
