--- a/Programmer/bin/50-programmer_usb.rules
+++ b/Programmer/bin/50-programmer_usb.rules
@@ -1,7 +1,16 @@
-ACTION=="add", ATTR{idVendor}=="33aa",ATTR{idProduct}=="0120", MODE:="666"
-ACTION=="add", ATTR{idVendor}=="0403",ATTR{idProduct}=="6014", MODE:="666"
-SUBSYSTEM=="usb",ATTR{idVendor}=="0403",ATTR{idProduct}=="6014",RUN+="/bin/sh -c 'echo -n $id:1.1 > /sys/bus/usb/drivers/ftdi_sio/unbind'"
+# Gowin GWU2X (33aa:0120): FTDI-based USB-JTAG programmer
+ATTRS{idVendor}=="33aa", ATTRS{idProduct}=="0120", MODE="0666", GROUP="plugdev", TAG+="uaccess"
+
+# Gowin GWU2U (33aa:0020): libusb-based USB-JTAG programmer (GoBridge ASSP)
+ATTRS{idVendor}=="33aa", ATTRS{idProduct}=="0020", MODE="0666", GROUP="plugdev", TAG+="uaccess"
+
+# Gowin USB2Peripheral multi-channel (33aa:0150)
+ATTRS{idVendor}=="33aa", ATTRS{idProduct}=="0150", MODE="0666", GROUP="plugdev", TAG+="uaccess"
+
+# FTDI FT232H/FT2232H (0403:6014) - unbind ftdi_sio for MPSSE mode
+ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", MODE="0666", GROUP="plugdev", TAG+="uaccess", \
+  RUN+="/bin/sh -c 'echo -n $id:1.1 > /sys/bus/usb/drivers/ftdi_sio/unbind 2>/dev/null || true'"
