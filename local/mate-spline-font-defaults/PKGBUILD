pkgname=mate-spline-font-defaults
pkgver=1.0.0
pkgrel=2
pkgdesc="System dconf defaults for Spline Sans across the MATE desktop"
arch=('any')
url="https://github.com/SorkinType/SplineSans"
license=('0BSD')
depends=('dconf' 'ttf-spline-sans' 'ttf-spline-sans-mono')
backup=('etc/dconf/profile/user'
        'etc/dconf/db/local.d/10-mate-spline-font-defaults'
        'etc/xdg/autostart/mate-spline-font-defaults-apply.desktop')
source=('dconf-profile-user'
        '10-mate-spline-font-defaults'
        'mate-spline-font-defaults-apply-once.sh'
        'mate-spline-font-defaults-apply.desktop')
sha256sums=('51eec44d50e4f6ec4ba887f1420077e60170a936f71d1a677bbab90b5d4b4bcd'
            '2d399ce2a197ed0f97c2f74739830bba3496c37b3d65711baf38c6bcb13edd05'
            '736edf720df931fe90fd684946f3809d7395021532a30671feaadd2f7090b2c5'
            '32328ce319b4813254ea7915f36f04d4cd3a5f4665ae45614ee4fe1c3aba2947')

package() {
  install -Dm644 "$srcdir/dconf-profile-user" "$pkgdir/etc/dconf/profile/user"
  install -Dm644 "$srcdir/10-mate-spline-font-defaults" \
    "$pkgdir/etc/dconf/db/local.d/10-mate-spline-font-defaults"
  install -Dm755 "$srcdir/mate-spline-font-defaults-apply-once.sh" \
    "$pkgdir/usr/lib/mate-spline-font-defaults/apply-once.sh"
  install -Dm644 "$srcdir/mate-spline-font-defaults-apply.desktop" \
    "$pkgdir/etc/xdg/autostart/mate-spline-font-defaults-apply.desktop"
}
