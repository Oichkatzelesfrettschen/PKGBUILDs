# Maintainer: local sidecar packaging for YSU-engine research

pkgname=nvhpc-sidecar-2411-multi
pkgver=24.11
pkgrel=1
pkgdesc='Side-by-side NVIDIA HPC SDK 24.11 multi-toolkit install for CUDA 11.8/12.6 PTXAS sweeps'
arch=('x86_64')
url='https://developer.nvidia.com/hpc-sdk'
license=('custom')
depends=('numactl' 'gcc')
makedepends=('bash')
optdepends=('env-modules')
conflicts=()
provides=()

_REL_YEAR=2024
_SHORT_VER=2411
_PKGBASE="nvhpc_${_REL_YEAR}_${_SHORT_VER}_Linux_${CARCH}_cuda_multi"
source=(
  "https://developer.download.nvidia.com/hpc-sdk/${pkgver}/${_PKGBASE}.tar.gz"
  "nvhpc-sidecar.sh"
  "nvhpc-sidecar-cuda11.8.sh"
  "nvhpc-sidecar-cuda12.6.sh"
)
sha256sums=(
  '0c27d66ed0e2d3007d30ac904922a9abf96475197dc0f4dcc6316d235a1dc0c3'
  'SKIP'
  'SKIP'
  'SKIP'
)

options=(!strip)

prepare() {
  cd "${srcdir}/${_PKGBASE}"
  sed -i 's/en_US\.UTF-8/C/g' "install_components/Linux_x86_64/${pkgver}/compilers/bin/makelocalrc"
}

package() {
  cd "${srcdir}/${_PKGBASE}"

  NVHPC_SILENT=true \
  NVHPC_INSTALL_DIR="${pkgdir}/opt/nvidia/hpc_sdk_sidecar" \
  bash ./install

  cd "${pkgdir}/opt/nvidia/hpc_sdk_sidecar/modulefiles"
  find . -type f -exec sed -i "s@${pkgdir}@@g" {} \;

  localrc_gcc="${NVHPC_LOCALRC_GCC:-gcc}"
  "${pkgdir}/opt/nvidia/hpc_sdk_sidecar/Linux_x86_64/${pkgver}/compilers/bin/makelocalrc" -x -gcc "${localrc_gcc}"

  cd "${srcdir}/${_PKGBASE}/install_components/Linux_${CARCH}/${pkgver}/compilers/license"
  install -Dm644 LICENSE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.txt"

  install -Dm755 "${srcdir}/nvhpc-sidecar.sh" "${pkgdir}/opt/nvidia/nvhpc-sidecar.sh"
  install -Dm755 "${srcdir}/nvhpc-sidecar-cuda11.8.sh" "${pkgdir}/opt/nvidia/nvhpc-sidecar-cuda11.8.sh"
  install -Dm755 "${srcdir}/nvhpc-sidecar-cuda12.6.sh" "${pkgdir}/opt/nvidia/nvhpc-sidecar-cuda12.6.sh"
}
